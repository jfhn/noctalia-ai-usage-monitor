{
  "id": "ai-usage-monitor",
  "name": "AI Usage Monitor",
  "author": "local",
  "description": "Shows Codex, OpenCode Go, Claude Code, and Cursor usage in the Noctalia bar.",
  "version": "0.1.0",
  "entryPoints": {
    "main": "Main.qml",
    "barWidget": "BarWidget.qml",
    "panel": "Panel.qml",
    "settings": "Settings.qml"
  },
  "metadata": {
    "icon": "brain",
    "defaultSettings": {
      "refreshIntervalMs": 60000,
      "staleAfterMs": 600000,
      "timezone": "UTC",
      "providers": {
        "codex": true,
        "opencode-go": true,
        "claude": true,
        "cursor": true
      },
      "barWindows": {
        "five_hour": true,
        "weekly": true,
        "monthly": true
      },
      "panelLayoutStyle": "default",
      "shortBarResetTime": false,
      "compactMode": false,
      "showCosts": true,
      "showUsedOnlyProvidersInBar": true
    }
  }
}
